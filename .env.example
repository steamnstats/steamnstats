PROJECT_NAME=SteamNStats
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+psycopg://steamnstats:steamnstats@postgres:5432/steamnstats
REDIS_URL=redis://redis:6379/0

STEAM_WEB_API_KEY=replace-me
# Set to http://localhost:8001 when running `docker compose --profile mock-steam up`.
# Leave empty to use the real Steam API and Store API hosts.
STEAM_ENDPOINT_URL=
STEAM_OPENID_REALM=http://localhost:8000
STEAM_OPENID_RETURN_URL=http://localhost:8000/auth/steam/callback
STEAM_OPENID_VERIFY=true

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-another-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
GAME_METADATA_TTL_HOURS=24
